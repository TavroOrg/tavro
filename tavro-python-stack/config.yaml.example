catalog_connector:
  azure:
    client_id: YOUR_AZURE_CLIENT_ID
    client_secret: YOUR_AZURE_CLIENT_SECRET
    tenant_id: YOUR_AZURE_TENANT_ID
    scope: https://YOUR_ORG.crm.dynamics.com/.default
    org_url: https://YOUR_ORG.crm.dynamics.com

  gemini:
    project_id: YOUR_PROJECT_ID
    location: global
    collection_id: YOUR_COLLECTION_ID
    engine_id: YOUR_ENGINE_ID
    client_id: YOUR_GOOGLE_CLIENT_ID
    client_secret: YOUR_GOOGLE_CLIENT_SECRET
    auth_uri: https://accounts.google.com/o/oauth2/auth
    token_uri: https://oauth2.googleapis.com/token

  servicenow:
    instance_url: https://your_instance.service-now.com
    username: USER_NAME
    password: YOUR_PASSWORD

  salesforce:
    instance_url: https://your_instance.salesforce.com
    api_version: v64.0
    access_token: YOUR_ACCESS_TOKEN

  bedrock:
    region: YOUR_AWS_REGION
    access_key: YOUR_AWS_ACCESS_KEY_ID
    secret_key: YOUR_AWS_SECRET_ACCESS_KEY

  databricks:
    workspace_url: https://your_instance.cloud.databricks.com
    databricks_token: YOUR_TOKEN

  snowflake:
    account: https://your_instance.snowflakecomputing.com
    database: DATABASE_NAME
    schema: SCHEMA_NAME
    token: YOUR_TOKEN

mcp_connectors:
  github:
    base_url: "https://api.githubcopilot.com/mcp/"
    token: YOUR_GITHUB_MCP_TOKEN

secrets:
  OPENAI_API_KEY: ""

fastapi:
  fast_api_host: "localhost"
  fast_api_port: "80"

mcp:
  mcp_host: "localhost"
  mcp_port: "9001"
  # Optional: set to your public ngrok URL when exposing the MCP server remotely.
  # Example: "https://abc123.ngrok-free.app"
  # Leave empty to default to http://localhost:9000
  mcp_root_url: ""

crewai:
  OTEL_SDK_DISABLED: true
  CREWAI_DISABLE_TELEMETRY: true
  CREWAI_TRACING_ENABLED: false

oAuth:
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
  COGNITO_HOSTED_UI : ""  
  COGNITO_USER_POOL_ID: ""
  COGNITO_AWS_REGION: ""
  COGNITO_CLIENT_ID: ""
  COGNITO_CLIENT_SECRET: ""  
  GITHUB_CLIENT_ID: ""
  GITHUB_CLIENT_SECRET: ""
  AZURE_CLIENT_ID: ""
  AZURE_CLIENT_SECRET: ""
  AZURE_TENANT_ID: ""
  ZITADEL_ISSUER: "http://localhost:8080"
  ZITADEL_CLIENT_ID: ""
  ZITADEL_CLIENT_SECRET: ""
  ZITADEL_REDIRECT_PATH: "/auth/callback"
  ZITADEL_SCOPES: "openid profile email"
  JWT_SIGNING_KEY: "super_secret_random_string_change_this"

databases:
  CORE_GLUE_DB_NAME: "core"
  CURATED_GLUE_DB_NAME: "curated"
  RISK_MANAGEMENT_GLUE_DB_NAME: "risk_management"

postgres:
  POSTGRES_HOST: "tavro-postgres"
  POSTGRES_PORT: "5432"
  POSTGRES_USER: "admin"
  POSTGRES_PASSWORD: "admin"
  POSTGRES_DB: "agent_db"

db:
  DB_Name: ""
  DB_USER: ""
  DB_PASSWORD: ""
  DB_HOST: "tavro-postgres"
  DB_PORT: "5432"
